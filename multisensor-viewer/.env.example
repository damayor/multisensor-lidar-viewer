# Debug Mode - Enable mock data and quality inspection tools
# Set to "true" to:
#   - Show quality status badge in header
#   - Enable SimulationPanel for testing data degradation scenarios
#   - Access quality metrics and error visualization
#
# Run with debug mode:
#   pnpm dev -- --mode debug
#   or manually:
#   VITE_DEBUG_MODE=true pnpm dev

VITE_DEBUG_MODE=false
